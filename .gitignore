# Dependencies
node_modules/

# Build output
dist/
src-tauri/target/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Environment — never commit any env file
.env
.env.*
!.env.example

# Tauri
src-tauri/gen/
claude-code/

# Playwright
test-results/
playwright-report/
.mas-certs/

# Signing material — private keys, CSRs, provisioning profiles must never
# be committed. Patterns use `**` so they match at any depth in the
# monorepo (apps/desktop/src-tauri/signing/ as well as the old path).
**/signing/
**/embedded.provisionprofile
*.key
*.p12
*.pfx
*.pem
*.mobileprovision
*.keystore
*.jks

# Credentials and secrets by pattern
credentials.json
secrets.json
*.secret
*secrets*.env

# Claude Code developer tooling
.claude/
.vercel
